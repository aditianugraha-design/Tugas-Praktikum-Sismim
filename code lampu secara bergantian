int led[] = {2, 3, 4, 5, 6, 7};

void setup(){
  for(int i = 0; i < 6; i++){
    pinMode(led[i], OUTPUT);
  }
}

void loop() {
  for(int i = 0; i < 3; i++){
    digitalWrite(led[i], HIGH);
  }
  
  for(int i = 3; i < 6; i++){
    digitalWrite(led[i], LOW);
  }

  delay(500);
  
  for(int i = 0; i < 3; i++){
    digitalWrite(led[i], LOW);
  }

  for(int i = 3; i < 6; i++){
    digitalWrite(led[i], HIGH); 
  }

  delay(500);
}
